# Database (Turso/libSQL for production, SQLite for local dev)
# For local dev: DATABASE_URL="file:./dev.db"
# For Turso: DATABASE_URL="libsql://your-db-name.turso.io?authToken=your-token"
DATABASE_URL="file:./dev.db"

# Authentication
JWT_SECRET="replace-with-a-long-random-string"

# App URL (change to your production URL when deploying)
# For Vercel: NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo User Credentials (for seeding)
SEED_DEMO_USER_EMAIL="demo@shareanalysis.app"
SEED_DEMO_USER_PASSWORD="DemoPass123!"
